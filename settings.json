{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(**)",
      "Write(**)",
      "Edit(**)",
      "Bash(python -m pytest *)",
      "Bash(python -m weave_runtime *)",
      "Bash(uv run *)",
      "Bash(git status)",
      "Bash(git log *)",
      "Bash(git diff *)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(drop database *)"
    ]
  }
}
